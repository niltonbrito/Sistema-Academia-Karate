	<parameter name="id" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT A.id_cbksc as ID, 
A.nome_abreviado_atleta as NOME, 
A.clube_atleta as CLUBE, 
B.faixa_exame as FAIXA, 
B.data_exame as DATA_EXAME
FROM tb_atletas as A
 INNER JOIN tbexamescbksc as B 
 ON B.id_atleta = A.id_atleta
 WHERE B.id_exame = $P{id}]]>
